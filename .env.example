# Hazem Gallery — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# GitHub Personal Access Token
# Create at: github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Required scope: public_repo
GH_TOKEN=your_github_personal_access_token_here

# GitHub repo info (change if you fork this project)
GH_OWNER=capzlzal
GH_REPO=Gallery
GH_BRANCH=main
GH_FILE=gallery-data.json
